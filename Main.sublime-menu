[
    {
        "id": "tools",
        "children": [
            { "caption": "-" },
            {
                "caption": "A6s",
                "id": "a6s",
                "children": [
                    { "caption": "Connect to Daemon", "command": "a6s_connect" },
                    { "caption": "Disconnect from Daemon", "command": "a6s_disconnect" },
                    { "caption": "-" },
                    { "caption": "Invoke Agent...", "command": "a6s_invoke_agent" },
                    { "caption": "-" },
                    { "caption": "Explain Selection", "command": "a6s_explain" },
                    { "caption": "Refactor Selection", "command": "a6s_refactor" },
                    { "caption": "Review Selection", "command": "a6s_review" },
                    { "caption": "Generate Tests for Selection", "command": "a6s_generate_tests" },
                    { "caption": "-" },
                    { "caption": "List Agents", "command": "a6s_list_agents" },
                    { "caption": "Execution Status", "command": "a6s_execution_status" },
                    { "caption": "-" },
                    { "caption": "Launch Background Task", "command": "a6s_background_launch" },
                    { "caption": "Task Output", "command": "a6s_background_output" },
                    { "caption": "List Background Tasks", "command": "a6s_list_tasks" },
                    { "caption": "Cancel Background Task...", "command": "a6s_cancel_task" },
                    { "caption": "-" },
                    { "caption": "Preview Pending Artifacts", "command": "a6s_preview_artifacts" },
                    { "caption": "Apply Pending Artifacts", "command": "a6s_apply_artifacts" },
                    { "caption": "-" },
                    {
                        "caption": "Settings",
                        "command": "edit_settings",
                        "args": {
                            "base_file": "${packages}/A6s/A6s.sublime-settings",
                            "default": "// A6s user settings\n{\n\t\n}\n"
                        }
                    }
                ]
            }
        ]
    },
    {
        "id": "preferences",
        "children": [
            {
                "caption": "Package Settings",
                "mnemonic": "P",
                "id": "package-settings",
                "children": [
                    {
                        "caption": "A6s",
                        "children": [
                            {
                                "caption": "Settings",
                                "command": "edit_settings",
                                "args": {
                                    "base_file": "${packages}/A6s/A6s.sublime-settings",
                                    "default": "// A6s user settings\n{\n\t\n}\n"
                                }
                            },
                            {
                                "caption": "Key Bindings",
                                "command": "edit_settings",
                                "args": {
                                    "base_file": "${packages}/A6s/Default.sublime-keymap",
                                    "default": "// A6s user key bindings\n[\n\t\n]\n"
                                }
                            }
                        ]
                    }
                ]
            }
        ]
    }
]
